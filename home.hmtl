<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Área do Sistema</title>
</head>
<body>

  <h1>Bem-vindo ao sistema da AutoCar 🚗</h1>
  <button onclick="logout()">Sair</button>

  <script>
    if (localStorage.getItem("logado") !== "true") {
      window.location.href = "index.html";
    }

    function logout() {
      localStorage.removeItem("logado");
      window.location.href = "index.html";
    }
  </script>

</body>
</html>